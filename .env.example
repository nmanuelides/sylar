# Copy to .env and fill in your Supabase project credentials.
# The app runs fully offline (IndexedDB) until these are provided.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: build server for one-click "Install on watch" QR codes (see server/README.md).
# Must be reachable from the phone that scans the QR (LAN IP or public deployment).
VITE_BUILD_SERVER_URL=
